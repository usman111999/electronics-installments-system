# Supabase
SUPABASE_URL=https://koldxkjvbifsszuhjrll.supabase.co
SUPABASE_ANON_KEY=sb_publishable_f1bUQf0wmSQQIxVm-BImQQ_QV4Z-9Jq
SUPABASE_SERVICE_KEY=sb_secret_u-egS1dMwSnIhFYNvu2h_w_d4vQjTqI

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT (used by Supabase auth - no override needed if using Supabase tokens)
JWT_SECRET=change-me-in-production-please

# WhatsApp provider configuration (optional - the system writes scheduled messages even if no provider is configured)
# Supported providers: twilio, meta, ultramsg, none
WHATSAPP_PROVIDER=none

# Twilio (if WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta WhatsApp Cloud API (if WHATSAPP_PROVIDER=meta)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=

# UltraMsg (if WHATSAPP_PROVIDER=ultramsg)
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=

# ---------------------------------------------------------------------------
# Device lock / unlock — FCM push channel
# ---------------------------------------------------------------------------
# 'fcm' uses Firebase Cloud Messaging HTTP v1.
# 'none' (or leaving the service-account unset) makes sendCommand() a no-op
# logger so the rest of the stack works in dev.
DEVICE_LOCK_PROVIDER=fcm

# Firebase project ID (defaults to project_id from the service-account JSON)
FCM_PROJECT_ID=

# EITHER point to a file path:
FCM_SERVICE_ACCOUNT_JSON_PATH=./firebase-service-account.json
# OR paste the raw JSON inline (escapes hell — prefer the path):
FCM_SERVICE_ACCOUNT_JSON=

# Optional override for the URL embedded in the enrollment QR (Android calls this).
# If unset, the backend uses the request's own host.
PUBLIC_API_BASE_URL=

