{
  "name": "electronics-instalments-backend",
  "version": "1.0.0",
  "description": "Backend API for Electronics Installments System",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed:admin": "node src/scripts/seedAdmin.js",
    "seed:permissions": "node src/scripts/seedPermissions.js",
    "seed:super-admin": "node src/scripts/seedSuperAdmin.js",
    "seed:all": "npm run seed:permissions && npm run seed:super-admin && npm run seed:admin",
    "db:apply": "node src/scripts/applySchema.js",
    "test": "jest --runInBand"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.21.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testMatch": ["**/__tests__/*.test.js"],
    "testTimeout": 15000
  }
}
