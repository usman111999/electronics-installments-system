<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.EisDeviceLock" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor" tools:targetApi="l">@color/primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.EisDeviceLock.Lock" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/lock_background</item>
        <item name="android:statusBarColor">@color/lock_background</item>
        <item name="android:navigationBarColor">@color/lock_background</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
