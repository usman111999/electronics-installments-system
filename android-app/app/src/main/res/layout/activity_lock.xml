<?xml version="1.0" encoding="utf-8"?>
<!--
  Fallback XML layout for LockActivity. The Compose UI in LockActivity.kt
  is the primary implementation; this file exists so an OEM tool that
  only inspects res/layout can confirm the lock screen exists.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/lock_background"
    android:padding="24dp">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_lock"
        android:contentDescription="@string/lock_title"
        android:tint="@color/accent" />

    <TextView
        android:id="@+id/lock_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textColor="@color/lock_foreground"
        android:textSize="28sp"
        android:textStyle="bold"
        android:text="@string/lock_title" />

    <TextView
        android:id="@+id/lock_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="@color/lock_foreground"
        android:textSize="18sp"
        android:text="@string/lock_default_message" />

    <Button
        android:id="@+id/btn_call_branch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:text="@string/lock_call_branch" />

    <Button
        android:id="@+id/btn_emergency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/lock_emergency_call" />
</LinearLayout>
