##############################################################################
#
#   Gradle start up script for POSIX-compatible shells.
#
#   IMPORTANT: This is a minimal wrapper script. To regenerate the canonical
#   wrapper run `gradle wrapper` inside the project root.
#
##############################################################################

APP_HOME=$(cd "$(dirname "$0")" >/dev/null && pwd)
exec gradle --project-dir "$APP_HOME" "$@"
